<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CJ Deparine Pagas | Cyber Portfolio</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syncopate:wght@400;700&family=Plus+Jakarta+Sans:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <style>
        /* Cyber Tech Variables */
        :root {
            --bg-black: #030303;
            --bg-darker: #080808;
            --bg-card: rgba(13, 13, 13, 0.7);
            --neon-gold: #ffb700;
            --neon-orange: #ff5500;
            --neon-blue: #00f0ff;
            --text-primary: #ffffff;
            --text-muted: #8e9bb0;
            --border-neon: rgba(255, 183, 0, 0.2);
            --grid-color: rgba(255, 183, 0, 0.02);
            --font-tech: 'Space Mono', monospace;
            --font-display: 'Syncopate', sans-serif;
        }

        /* Clean Reset */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        /* Cyberpunk Grid Background */
        body {
            background-color: var(--bg-black);
            background-image: 
                linear-gradient(to right, var(--grid-color) 1px, transparent 1px),
                linear-gradient(to bottom, var(--grid-color) 1px, transparent 1px);
            background-size: 40px 40px;
            color: var(--text-primary);
            overflow-x: hidden;
            line-height: 1.6;
            position: relative;
        }

        /* Ambient Glow Blobs */
        body::before {
            content: '';
            position: absolute;
            top: 10%;
            left: -10%;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(255, 183, 0, 0.08) 0%, transparent 70%);
            z-index: -1;
            pointer-events: none;
        }

        body::after {
            content: '';
            position: absolute;
            bottom: 20%;
            right: -10%;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(0, 240, 255, 0.05) 0%, transparent 70%);
            z-index: -1;
            pointer-events: none;
        }

        /* Sci-Fi Navigation */
        header {
            position: fixed;
            top: 0;
            width: 100%;
            background-color: rgba(3, 3, 3, 0.9);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            padding: 20px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
            border-bottom: 1px solid rgba(255, 183, 0, 0.1);
        }

        .logo {
            font-family: var(--font-display);
            font-size: 1.2rem;
            font-weight: 700;
            letter-spacing: -1px;
            color: var(--text-primary);
        }

        .logo span {
            color: var(--neon-gold);
            text-shadow: 0 0 10px rgba(255, 183, 0, 0.5);
        }

        .nav-links {
            display: flex;
            gap: 32px;
        }

        .nav-links a {
            font-family: var(--font-tech);
            font-size: 0.85rem;
            text-transform: uppercase;
            text-decoration: none;
            color: var(--text-muted);
            transition: all 0.3s ease;
            letter-spacing: 1px;
        }

        .nav-links a:hover {
            color: var(--neon-gold);
            text-shadow: 0 0 8px rgba(255, 183, 0, 0.5);
        }

        .menu-toggle {
            display: none;
            flex-direction: column;
            cursor: pointer;
            gap: 6px;
        }

        .bar {
            width: 25px;
            height: 2px;
            background-color: var(--text-primary);
            transition: 0.3s ease;
        }

        /* Hero HUD Section */
        #hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 0 20px;
            position: relative;
        }

        .hud-frame {
            border: 1px solid var(--border-neon);
            padding: 60px 40px;
            background: rgba(8, 8, 8, 0.8);
            border-radius: 4px;
            position: relative;
            max-width: 800px;
            box-shadow: inset 0 0 30px rgba(255, 183, 0, 0.05);
        }

        /* Corner Brackets for HUD */
        .hud-frame::before, .hud-frame::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            border-color: var(--neon-gold);
            border-style: solid;
            pointer-events: none;
        }

        .hud-frame::before {
            top: -2px; left: -2px;
            border-width: 3px 0 0 3px;
        }

        .hud-frame::after {
            bottom: -2px; right: -2px;
            border-width: 0 3px 3px 0;
        }

        .hero-sys-status {
            font-family: var(--font-tech);
            color: var(--neon-blue);
            font-size: 0.85rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .pulse-dot {
            width: 8px;
            height: 8px;
            background-color: var(--neon-blue);
            border-radius: 50%;
            box-shadow: 0 0 8px var(--neon-blue);
            animation: pulse 1.5s infinite;
        }

        .hud-frame h1 {
            font-family: var(--font-display);
            font-size: 4rem;
            line-height: 1.1;
            letter-spacing: -2px;
            margin-bottom: 20px;
        }

        .hud-frame h1 span {
            color: var(--neon-gold);
            text-shadow: 0 0 20px rgba(255, 183, 0, 0.4);
        }

        .hud-frame p {
            font-size: 1.15rem;
            color: var(--text-muted);
            max-width: 600px;
            margin: 0 auto 36px auto;
        }

        /* Glowing Cyber Button */
        .cyber-btn {
            font-family: var(--font-tech);
            background: transparent;
            border: 1px solid var(--neon-gold);
            color: var(--neon-gold);
            padding: 14px 36px;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            position: relative;
            transition: all 0.3s ease;
            text-shadow: 0 0 5px rgba(255, 183, 0, 0.5);
            box-shadow: 0 0 15px rgba(255, 183, 0, 0.1);
        }

        .cyber-btn:hover {
            background: var(--neon-gold);
            color: var(--bg-black);
            box-shadow: 0 0 25px rgba(255, 183, 0, 0.4);
            transform: translateY(-2px);
        }

        /* Container & Sections */
        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 24px;
        }

        section {
            padding: 120px 0;
            position: relative;
        }

        .section-header {
            text-align: center;
            margin-bottom: 70px;
        }

        .section-header h2 {
            font-family: var(--font-display);
            font-size: 2.5rem;
            letter-spacing: -1px;
            margin-bottom: 10px;
        }

        .section-header h2 span {
            color: var(--neon-gold);
        }

        .section-header .tag {
            font-family: var(--font-tech);
            color: var(--neon-blue);
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 3px;
        }

        /* Cyber About Grid */
        .about-grid {
            display: grid;
            grid-template-columns: 1.1fr 1.9fr;
            gap: 60px;
            align-items: center;
        }

        .profile-container {
            position: relative;
            border: 1px solid var(--border-neon);
            padding: 12px;
            background: rgba(8,8,8,0.5);
        }

        .profile-container::before {
            content: '';
            position: absolute;
            top: -1px; left: -1px;
            width: 15px; height: 15px;
            border-top: 3px solid var(--neon-blue);
            border-left: 3px solid var(--neon-blue);
        }

        .profile-pic {
            width: 100%;
            height: auto;
            display: block;
            border: 1px solid rgba(255, 255, 255, 0.1);
            filter: grayscale(100%) contrast(110%);
            transition: all 0.4s ease;
        }

        .profile-container:hover .profile-pic {
            filter: grayscale(0%) contrast(100%);
        }

        .about-text h3 {
            font-family: var(--font-display);
            font-size: 1.5rem;
            margin-bottom: 20px;
            color: var(--neon-gold);
        }

        .about-text p {
            font-size: 1.1rem;
            color: var(--text-muted);
            margin-bottom: 30px;
        }

        /* High-Tech Spec Cards */
        .spec-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        .spec-card {
            background: var(--bg-card);
            border: 1px solid rgba(255, 255, 255, 0.05);
            padding: 24px;
            border-left: 3px solid var(--neon-gold);
            position: relative;
            transition: all 0.3s ease;
        }

        .spec-card:hover {
            border-left-color: var(--neon-blue);
            background: rgba(0, 240, 255, 0.02);
            transform: scale(1.02);
        }

        .spec-card h4 {
            font-family: var(--font-tech);
            color: var(--text-muted);
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 6px;
        }

        .spec-card p {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text-primary);
            margin: 0;
        }

        /* Tech Skills Section */
        .skills-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
        }

        .tech-box {
            background: var(--bg-card);
            border: 1px solid rgba(255, 255, 255, 0.05);
            padding: 30px 24px;
            text-align: left;
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .tech-box::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 3px;
            height: 0;
            background: var(--neon-gold);
            transition: height 0.3s ease;
        }

        .tech-box:hover::before {
            height: 100%;
        }

        .tech-box:hover {
            border-color: var(--border-neon);
            box-shadow: 0 10px 25px rgba(255, 183, 0, 0.05);
            transform: translateY(-5px);
        }

        .tech-num {
            font-family: var(--font-tech);
            color: var(--neon-blue);
            font-size: 0.85rem;
            margin-bottom: 15px;
            display: block;
        }

        .tech-box h3 {
            font-family: var(--font-display);
            font-size: 1.1rem;
            margin-bottom: 8px;
            letter-spacing: -0.5px;
        }

        .tech-box p {
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        /* Certificate Spotlight (Target Frame) */
        .cert-hud-container {
            max-width: 850px;
            margin: 0 auto;
            border: 1px solid rgba(255, 255, 255, 0.08);
            background: var(--bg-darker);
            position: relative;
            padding: 24px;
        }

        .cert-hud-container::before {
            content: '[ ACHIEVEMENT LOADED ]';
            position: absolute;
            top: -12px;
            left: 20px;
            font-family: var(--font-tech);
            font-size: 0.75rem;
            color: var(--neon-gold);
            background: var(--bg-black);
            padding: 0 10px;
        }

        .cert-frame {
            border: 1px solid var(--border-neon);
            position: relative;
            overflow: hidden;
        }

        .cert-image {
            width: 100%;
            height: auto;
            display: block;
            filter: contrast(105%);
            transition: transform 0.6s ease;
        }

        .cert-hud-container:hover .cert-image {
            transform: scale(1.02);
        }

        .cert-desc {
            padding: 30px 10px 10px 10px;
            text-align: center;
        }

        .cert-desc h3 {
            font-family: var(--font-display);
            font-size: 1.8rem;
            color: var(--text-primary);
            margin-bottom: 8px;
        }

        .cert-desc p {
            font-family: var(--font-tech);
            color: var(--neon-blue);
            font-size: 0.95rem;
        }

        /* Interactive Cyber Terminal */
        .terminal-container {
            max-width: 850px;
            margin: 60px auto 0 auto;
            background: #050505;
            border: 1px solid var(--neon-blue);
            border-radius: 6px;
            overflow: hidden;
            box-shadow: 0 15px 40px rgba(0, 240, 255, 0.1);
        }

        .terminal-bar {
            background: #111;
            padding: 10px 20px;
            display: flex;
            align-items: center;
            gap: 8px;
            border-bottom: 1px solid rgba(0, 240, 255, 0.2);
        }

        .term-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
        }

        .term-dot.red { background: #ff5f56; }
        .term-dot.yellow { background: #ffbd2e; }
        .term-dot.green { background: #27c93f; }

        .term-title {
            font-family: var(--font-tech);
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-left: 10px;
        }

        .terminal-body {
            padding: 24px;
            font-family: var(--font-tech);
            font-size: 0.9rem;
            color: #27c93f; /* Matrix Green */
            background-color: #030303;
            min-height: 250px;
            max-height: 400px;
            overflow-y: auto;
        }

        .term-input-line {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 15px;
        }

        .term-btn {
            background: transparent;
            border: 1px solid #27c93f;
            color: #27c93f;
            padding: 8px 16px;
            cursor: pointer;
            font-family: var(--font-tech);
            font-size: 0.8rem;
            transition: all 0.3s;
        }

        .term-btn:hover {
            background: #27c93f;
            color: #000;
        }

        /* Footer */
        footer {
            text-align: center;
            padding: 45px 0;
            border-top: 1px solid rgba(255, 183, 0, 0.1);
            color: var(--text-muted);
            font-family: var(--font-tech);
            font-size: 0.8rem;
            background-color: var(--bg-darker);
        }

        /* Animations */
        @keyframes pulse {
            0% { opacity: 0.3; }
            50% { opacity: 1; }
            100% { opacity: 0.3; }
        }

        /* Responsiveness */
        @media (max-width: 900px) {
            .about-grid {
                grid-template-columns: 1fr;
                gap: 40px;
            }

            .profile-container {
                max-width: 320px;
                margin: 0 auto;
            }

            .hud-frame h1 {
                font-size: 2.8rem;
            }
        }

        @media (max-width: 768px) {
            header {
                padding: 15px 24px;
            }

            .nav-links {
                display: none;
                flex-direction: column;
                position: absolute;
                top: 65px;
                left: 0;
                width: 100%;
                background-color: var(--bg-black);
                padding: 40px;
                border-bottom: 1px solid var(--border-neon);
                text-align: center;
                gap: 25px;
            }

            .nav-links.active {
                display: flex;
            }

            .menu-toggle {
                display: flex;
            }

            .menu-toggle.active .bar:nth-child(1) {
                transform: translateY(8px) rotate(45deg);
            }

            .menu-toggle.active .bar:nth-child(2) {
                opacity: 0;
            }

            .menu-toggle.active .bar:nth-child(3) {
                transform: translateY(-8px) rotate(-45deg);
            }

            .spec-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>

    <!-- Sci-Fi Top Header -->
    <header id="header">
        <div class="logo">CJ_<span>PAGAS</span></div>
        <nav>
            <ul class="nav-links">
                <li><a href="#hero">// Home</a></li>
                <li><a href="#about">// About</a></li>
                <li><a href="#skills">// Skills</a></li>
                <li><a href="#achievements">// Archive</a></li>
            </ul>
            <div class="menu-toggle" id="mobile-menu">
                <span class="bar"></span>
                <span class="bar"></span>
                <span class="bar"></span>
            </div>
        </nav>
    </header>

    <!-- Hero HUD Section -->
    <section id="hero">
        <div class="hud-frame">
            <div class="hero-sys-status">
                <div class="pulse-dot"></div> CORE SYSTEM ACTIVE // ONLINE
            </div>
            <h1>CJ Deparine <span>Pagas</span></h1>
            <p>Creative Editor & Document Architect bridging high-structure layout designs with defensive cybersecurity knowledge.</p>
            <button onclick="scrollToAbout()" class="cyber-btn">INITIALIZE SYSTEM</button>
        </div>
    </section>

    <!-- About Section -->
    <section id="about">
        <div class="container">
            <div class="section-header">
                <span class="tag">System Profile</span>
                <h2>Biographical <span>Data</span></h2>
            </div>
            <div class="about-grid">
                <div class="profile-container">
                    <img src="img/profile.jpg" alt="CJ Pagas" class="profile-pic">
                </div>
                <div class="about-text">
                    <h3>// DESIGNER & DEFENDER</h3>
                    <p>Working at the intersection of creative file compilation, high-end formatting, and secure computing. Specializing in making raw documents and designs look stunningly polished while maintaining information systems logic.</p>
                    
                    <div class="spec-grid">
                        <div class="spec-card">
                            <h4>STATUS</h4>
                            <p>3rd Year BSIS Student</p>
                        </div>
                        <div class="spec-card">
                            <h4>AGE / INTEL</h4>
                            <p>21 Years of Age</p>
                        </div>
                        <div class="spec-card">
                            <h4>CORE ABILITY</h4>
                            <p>Doc Design & Formatting</p>
                        </div>
                        <div class="spec-card">
                            <h4>ZONE</h4>
                            <p>Davao, Philippines</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Skills Section -->
    <section id="skills">
        <div class="container">
            <div class="section-header">
                <span class="tag">Capabilities Matrix</span>
                <h2>Technical <span>Arsenal</span></h2>
            </div>
            <div class="skills-grid">
                <div class="tech-box">
                    <span class="tech-num">01_</span>
                    <h3>Creative Editing</h3>
                    <p>Translating complex visual concepts into polished, professional graphics and asset formats.</p>
                </div>
                <div class="tech-box">
                    <span class="tech-num">02_</span>
                    <h3>Doc Compiling</h3>
                    <p>Expert structuring, layout grid configuration, and formatting for academic or corporate files.</p>
                </div>
                <div class="tech-box">
                    <span class="tech-num">03_</span>
                    <h3>Security Focus</h3>
                    <p>Junior Cybersecurity principles covering network architecture protection and threat diagnostics.</p>
                </div>
                <div class="tech-box">
                    <span class="tech-num">04_</span>
                    <h3>HTML & CSS</h3>
                    <p>Writing neat, ultra-custom web structures and dynamic layouts from absolute scratch.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Achievements Section -->
    <section id="achievements">
        <div class="container">
            <div class="section-header">
                <span class="tag">Archive logs</span>
                <h2>Verified <span>Credentials</span></h2>
            </div>
            <div class="cert-hud-container">
                <div class="cert-frame">
                    <img src="img/certificate.png" alt="Cisco Certificate of Course Completion" class="cert-image">
                </div>
                <div class="cert-desc">
                    <h3>Junior Cybersecurity Analyst</h3>
                    <p>Issued by Cisco Networking Academy | Status: VERIFIED</p>
                </div>
            </div>

            <!-- INTERACTIVE MATRIX TERMINAL -->
            <div class="terminal-container">
                <div class="terminal-bar">
                    <span class="term-dot red"></span>
                    <span class="term-dot yellow"></span>
                    <span class="term-dot green"></span>
                    <span class="term-title">cj_terminal_v2.01 // run: cisco_verification.sh</span>
                </div>
                <div class="terminal-body" id="term-output">
                    <p>> initializing system logs...</p>
                    <p>> connection established with Cisco Networking Academy</p>
                    <p>> cjpagas credentials successfully loaded</p>
                    <p>> click standard actions to command terminal:</p>
                </div>
                <div style="padding: 15px; border-top: 1px solid rgba(0, 240, 255, 0.1); background-color: #050505; display: flex; gap: 10px; flex-wrap: wrap;">
                    <button class="term-btn" onclick="runTrace()">$ RUN TRACE</button>
                    <button class="term-btn" onclick="checkSkills()">$ SKILL SCAN</button>
                    <button class="term-btn" onclick="scanContacts()" style="border-color: #ffb700; color: #ffb700;">$ SCAN CONTACTS</button>
                    <button class="term-btn" onclick="clearTerm()" style="border-color: #8e9bb0; color: #8e9bb0;">$ CLEAR SCREEN</button>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <p>// SYSTEM COMPILED IN 2026 BY CJ DEPARINE PAGAS // PROTOCOL SECURED</p>
    </footer>

    <script>
        // Mobile menu toggle
        const menuToggle = document.getElementById('mobile-menu');
        const navLinks = document.querySelector('.nav-links');

        menuToggle.addEventListener('click', () => {
            menuToggle.classList.toggle('active');
            navLinks.classList.toggle('active');
        });

        // Close mobile menu on click
        const links = document.querySelectorAll('.nav-links a');
        links.forEach(link => {
            link.addEventListener('click', () => {
                menuToggle.classList.remove('active');
                navLinks.classList.remove('active');
            });
        });

        function scrollToAbout() {
            document.querySelector('#about').scrollIntoView({ behavior: 'smooth' });
        }

        // Mini Terminal Scripts
        const output = document.getElementById('term-output');

        function appendLine(text, delay) {
            setTimeout(() => {
                const p = document.createElement('p');
                p.innerHTML = text;
                output.appendChild(p);
                output.scrollTop = output.scrollHeight;
            }, delay);
        }

        function runTrace() {
            appendLine("> launching trace request...", 0);
            appendLine("> checking IP nodes ... [OK]", 500);
            appendLine("> trace successfully mapped target: <strong>cj_pagas_cyber_analyst_credential_id_2026</strong>", 1000);
            appendLine("> certificate authority: <strong>Cisco Academy</strong>", 1500);
            appendLine("> system validation status: <strong>SECURED & VALID</strong>", 2000);
        }

        function checkSkills() {
            appendLine("> executing core ability diagnostics...", 0);
            appendLine("> doc_formatting.sys: <strong>100% Efficiency</strong>", 600);
            appendLine("> graphic_layout.exe: <strong>High Capability</strong>", 1200);
            appendLine("> cyber_defense.dll: <strong>Active Watchdog Enabled</strong>", 1800);
        }

        // Decryption Contact Script with FB Account
        function scanContacts() {
            appendLine("> initiating contact node scan...", 0);
            appendLine("> decryp_comms_port_80.sh: processing...", 300);
            appendLine("> decryp_comms_port_25.sh: processing...", 600);
            appendLine("> decryp_social_uplink_443.sh: processing...", 900);
            appendLine("> decryption successful. displaying communication lines:", 1200);
            appendLine("> -------------------------------------------------------------", 1300);
            appendLine("> 📧 EMAIL PORT [25]: <a href='mailto:cjpagas7@gmail.com' style='color: #ffb700; text-decoration: underline; font-weight: bold;'>cjpagas7@gmail.com</a>", 1600);
